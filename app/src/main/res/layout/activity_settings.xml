<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="top"
    android:background="#1D1121"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <ImageButton
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@null"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/white"
            android:fontFamily="@font/google_sans"
            android:textSize="30sp"
            android:textStyle="bold"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_notifs_top"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This device"
            android:textColor="@color/white"
            android:fontFamily="@font/google_sans"
            android:textSize="20sp"
            android:layout_margin="15dp"
            android:textStyle="bold"/>

        <com.google.android.material.textfield.TextInputEditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:paddingVertical="15dp"
            android:paddingStart="5dp"
            android:paddingEnd="10dp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/bg_settings_input"
            android:drawableEnd="@drawable/ic_edit"
            android:maxLines="1"
            android:inputType="text"
            android:imeOptions="actionDone"
            android:text="Jannik Dropzone"
            android:textSize="17sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server"
            android:textColor="@color/white"
            android:fontFamily="@font/google_sans"
            android:textSize="20sp"
            android:layout_marginHorizontal="15dp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="shareit.cns-studios.com"
            android:textColor="@color/white"
            android:fontFamily="@font/google_sans"
            android:textSize="18sp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginBottom="15dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_notifs_bottom"
        android:layout_marginTop="10dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="App Version"
            android:textColor="@color/white"
            android:fontFamily="@font/google_sans"
            android:textSize="20sp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="15dp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v0.0.0"
            android:textColor="@color/white"
            android:fontFamily="@font/google_sans"
            android:textSize="15sp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginBottom="50dp"/>
        
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            android:backgroundTint="#762C8E"
            android:textColor="@color/white"
            android:fontFamily="@font/google_sans"
            android:textSize="20dp"
            android:text="Check for updates"/>
    </LinearLayout>

        <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="15dp"
        android:textColor="#1D1121"
        android:backgroundTint="#E599FE"
        android:fontFamily="@font/google_sans"
        android:textSize="20dp"
        android:textStyle="bold"
        android:text="Sign out"
        app:icon="@drawable/ic_logout"
        app:iconSize="26dp"
        app:iconTint="#1D1121"
        app:iconGravity="textStart"/>

</LinearLayout>