<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.motion.widget.MotionLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:app2="http://schemas.android.com/apk/res-auto"
    android:id="@+id/motion_layout"
    android:layout_width="match_parent"
    android:layout_height="88dp"
    android:paddingBottom="8dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    app:layoutDescription="@xml/item_file_scene">

    <LinearLayout
        android:id="@+id/layout_content"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_file_item"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_file_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_image"
            app2:tint="@color/white" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_file_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="CNS Logo.png"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_file_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="1 B • Uploaded 1 day ago • Expir..."
                android:textColor="#8EFFFFFF"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_bookmark"
        android:layout_width="64dp"
        android:layout_height="match_parent"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_bookmark_btn"
        android:padding="18dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_bookmark"
        android:paddingHorizontal="10dp"
        app:tint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btn_download"
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_download_btn"
        android:padding="18dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_download"
        app:tint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btn_bookmark"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.motion.widget.MotionLayout>